# Molbazar2005 Backend — copy to .env and fill values

# Server
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/molbozor

# Auth
JWT_SECRET=super_secret_key

# Email OTP (Resend)
RESEND_API_KEY=your_resend_key
APP_FROM_EMAIL="Molbozor <no-reply@yourdomain.com>"

# Banner/upload rasmlari uchun asosiy URL (relative yo‘llarni to‘liq qilish). VPS da: https://molbazar.uz
# PUBLIC_URL=https://molbazar.uz

# Cloudinary (image upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
